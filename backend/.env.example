PORT=5000
DATABASE_URL=mysql://root:password@localhost:3306/lazeepos
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_chars
JWT_EXPIRES_IN=7d
NODE_ENV=development
CENTRAL_DOMAIN=lazeepos.com

# Superadmin system utilities
MYSQL_BACKUP_PATH=/var/backups/lazeepos
LOG_DIR=/var/log/lazeepos

# Midtrans Payment Gateway
# Get keys from: https://dashboard.midtrans.com -> Settings -> Access Keys
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=SB-Mid-server-XXXXXXXXXXXX
MIDTRANS_CLIENT_KEY=SB-Mid-client-XXXXXXXXXXXX
FRONTEND_URL=http://localhost:5173
