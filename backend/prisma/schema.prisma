// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  central
  admin
  kasir
}

enum TxnStatus {
  COMPLETED
  VOID
}

enum DiscountType {
  PERCENT_OFF
  PERCENT_OFF_MIN_AMOUNT
  BUY_X_GET_Y
  FIXED_AMOUNT
}

enum APStatus {
  PENDING
  PAID
  OVERDUE
}

enum PlanStatus {
  PENDING
  ACTIVE
  SUSPENDED
  TRIAL
}

model Tenant {
  id            String   @id @default(uuid())
  name          String
  subdomain     String   @unique
  themeMode     String   @default("light")
  primaryColor  String   @default("#3B82F6")
  logoUrl       String?
  logoShape     String   @default("square")
  landingPageConfig Json?
  status        PlanStatus @default(TRIAL)
  planId        String?
  trialEndsAt   DateTime?
  suspendedAt   DateTime?
  suspendedReason String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Soft‑delete flag – tenant can be suspended
  isActive      Boolean  @default(true)
  // Relationships
  users         User[]   @relation("TenantUsers")
  products      Product[] @relation("TenantProducts")
  warehouses    Warehouse[] @relation("TenantWarehouses")
  cashflows     CashFlow[] @relation("TenantCashFlows")
  webhooks      Webhook[] @relation("TenantWebhooks")
  discounts     Discount[] @relation("TenantDiscounts")
  suppliers     Supplier[] @relation("TenantSuppliers")
  accountsPayable AccountPayable[] @relation("TenantAP")
  shifts        Shift[]  @relation("TenantShifts")
  transactions  Transaction[] @relation("TenantTransactions")
  receipts      Receipt[] @relation("TenantReceipts")
  plan          Plan?    @relation("TenantPlan", fields: [planId], references: [id])
  subscription  Subscription?
  paymentTransactions PaymentTransaction[] @relation("TenantPaymentTransactions")
  tickets       Ticket[]
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String?
  passwordHash  String
  role          Role     @default(admin)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // FK
  tenantId      String?
  tenant        Tenant?  @relation("TenantUsers", fields: [tenantId], references: [id])
  // Soft‑delete for users
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  shifts        Shift[]  @relation("ShiftKasir")
  transactions  Transaction[] @relation("TxnKasir")
  tickets       Ticket[]
  ticketReplies TicketReply[]
}

// =======================
//  Business Entities (scoped to Tenant)
// =======================
model Product {
  id            String   @id @default(uuid())
  name          String
  sku           String?  @unique
  description   String?
  price         Float    // master price
  costPrice     Float?
  category      String?
  imageUrl      String?
  isActive      Boolean  @default(true)
  isPinned      Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String
  tenant        Tenant   @relation("TenantProducts", fields: [tenantId], references: [id])
  warehouse     Warehouse?
  transactionItems TransactionItem[] @relation("TxnItemProduct")
}

model Warehouse {
  id            String   @id @default(uuid())
  quantity      Int
  reorderLevel  Int      @default(5)
  location      String?  // warehouse / rack
  lastUpdated   DateTime @updatedAt
  lastRestocked DateTime?
  tenantId      String
  tenant        Tenant   @relation("TenantWarehouses", fields: [tenantId], references: [id])
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id])
}

model CashFlow {
  id              String   @id @default(uuid())
  type            String   // 'sale', 'expense', 'income'
  amount          Float
  description     String
  transactionDate DateTime @default(now())
  userId          String?
  tenantId        String
  tenant          Tenant   @relation("TenantCashFlows", fields: [tenantId], references: [id])
}

model Webhook {
  id            String   @id @default(uuid())
  url           String
  events        String   // comma-separated, e.g., 'transaction.created,product.updated'
  secret        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  tenantId      String
  tenant        Tenant   @relation("TenantWebhooks", fields: [tenantId], references: [id])
}

model IdempotencyKey {
  id            String   @id
  responseBody  Json
  statusCode    Int
  createdAt     DateTime @default(now())
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contact       String?
  tenantId      String
  tenant        Tenant   @relation("TenantSuppliers", fields: [tenantId], references: [id])
  accountsPayable AccountPayable[] @relation("SupplierAP")
}

model AccountPayable {
  id            String   @id @default(uuid())
  amount        Float
  dueDate       DateTime
  status        APStatus @default(PENDING)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenantId      String
  tenant        Tenant   @relation("TenantAP", fields: [tenantId], references: [id])
  supplierId    String
  supplier      Supplier @relation("SupplierAP", fields: [supplierId], references: [id])
}

model Discount {
  id                String   @id @default(uuid())
  name              String
  discountType      String   // 'percentage', 'fixed_amount', 'bogo'
  discountValue     Float
  appliesTo         String   @default("all") // 'all', 'category', 'product'
  appliesToId       String?
  appliesToCategory String?
  minQuantity       Int      @default(1)
  minOrderAmount    Float?
  startsAt          DateTime?
  endsAt            DateTime?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenantId          String
  tenant            Tenant   @relation("TenantDiscounts", fields: [tenantId], references: [id])
}

model Plan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  monthlyPrice  Float    @default(0)
  maxProducts   Int      @default(100)
  maxUsers      Int      @default(3)
  maxBranches   Int      @default(1)
  features      Json
  status        PlanStatus @default(ACTIVE)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenants       Tenant[] @relation("TenantPlan")
  subscriptions Subscription[]
  paymentTransactions PaymentTransaction[]
}

model Subscription {
  id                 String   @id @default(uuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  planId             String
  plan               Plan     @relation(fields: [planId], references: [id])
  billingCycle       String   @default("monthly") // monthly, yearly
  status             String   @default("active")  // active, canceled, past_due
  nextBillingAt      DateTime?
  lastPaymentAt      DateTime?
  paymentProvider    String?
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// =======================
//  Transaction & Shift
// =======================
model Shift {
  id            String   @id @default(uuid())
  openedAt      DateTime
  closedAt      DateTime?
  openingCash   Float
  closingCash   Float?
  kasirId       String
  kasir         User     @relation("ShiftKasir", fields: [kasirId], references: [id])
  tenantId      String
  tenant        Tenant   @relation("TenantShifts", fields: [tenantId], references: [id])
  transactions  Transaction[] @relation("ShiftTransactions")
}

model Transaction {
  id            String   @id @default(uuid())
  status        TxnStatus @default(COMPLETED)
  totalAmount   Float
  paidAmount    Float
  change        Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  // Soft delete flag – Kasir can only void
  isVoided      Boolean  @default(false)
  tenantId      String
  tenant        Tenant   @relation("TenantTransactions", fields: [tenantId], references: [id])
  shiftId       String
  shift         Shift    @relation("ShiftTransactions", fields: [shiftId], references: [id])
  kasirId       String   // who processed (even if voided)
  kasir         User     @relation("TxnKasir", fields: [kasirId], references: [id])
  items         TransactionItem[] @relation("TxnItems")
}

model TransactionItem {
  id            String   @id @default(uuid())
  quantity      Int
  unitPrice     Float    // price at time of sale (may already include discount)
  discountApplied Float? // amount discounted on this line
  productId     String
  product       Product  @relation("TxnItemProduct", fields: [productId], references: [id])
  transactionId String
  transaction   Transaction @relation("TxnItems", fields: [transactionId], references: [id])
}

model Receipt {
  id             String        @id @default(uuid())
  receiptNumber  String        @unique
  customerName   String?
  subtotalAmount Float
  discountAmount Float
  taxAmount      Float
  totalAmount    Float
  paidAmount     Float
  changeGiven    Float
  paymentMethod  String        @default("cash")
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenantId       String
  tenant         Tenant        @relation("TenantReceipts", fields: [tenantId], references: [id])
  items          ReceiptItem[] @relation("ReceiptItems")
}

model ReceiptItem {
  id              String   @id @default(uuid())
  productId       String?
  productName     String
  sku             String?
  quantity        Int
  unitPrice       Float
  discountApplied Float
  totalPrice      Float
  receiptId       String
  receipt         Receipt  @relation("ReceiptItems", fields: [receiptId], references: [id])
}

model PaymentTransaction {
  id              String    @id @default(uuid())
  tenantId        String
  tenant          Tenant    @relation("TenantPaymentTransactions", fields: [tenantId], references: [id])
  planId          String
  plan            Plan      @relation(fields: [planId], references: [id])
  orderId         String    @unique
  snapToken       String?
  snapRedirectUrl String?
  amount          Float
  billingCycle    String
  status          String    @default("pending")
  paymentType     String?
  paidAt          DateTime?
  activeFrom      DateTime?
  activeUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// =======================
//  Ticketing System
// =======================
model Ticket {
  id          String   @id @default(uuid())
  subject     String
  description String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  userAgent   String?  // Context of the user's browser/OS
  
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  replies     TicketReply[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TicketReply {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  
  // If replied by a tenant user
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  // If replied by central admin
  isCentral Boolean  @default(false)
  
  message   String
  
  createdAt DateTime @default(now())
}

// =======================
//  Version Management
// =======================
model SystemRelease {
  id           String   @id @default(uuid())
  version      String   @unique
  releaseNotes String   @db.Text
  isMandatory  Boolean  @default(false)
  publishedAt  DateTime @default(now())
}



// =======================
//  System Logs & Monitoring
// =======================
model CentralAuditLog {
  id        String   @id @default(uuid())
  action    String
  actorId   String?  // Superadmin user ID
  targetId  String?  // The ID of the affected resource (tenant, plan, etc)
  details   String?  @db.Text // JSON string containing metadata
  createdAt DateTime @default(now())
}

model SystemErrorLog {
  id        String   @id @default(uuid())
  message   String   @db.Text
  stack     String?  @db.Text
  path      String?
  method    String?
  tenantId  String?
  createdAt DateTime @default(now())
}
